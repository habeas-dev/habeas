{
  "name": "habeas",
  "version": "0.0.1",
  "description": "Reclaim your own personal data from services that lock it behind non-automatable walls — a browser extension that extracts your data within your own session.",
  "license": "AGPL-3.0-or-later",
  "keywords": [
    "personal-data",
    "data-portability",
    "gdpr",
    "habeas-data",
    "browser-extension",
    "self-hosted",
    "scraper"
  ],
  "homepage": "https://habeas.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/habeas-dev/habeas.git"
  },
  "bugs": {
    "url": "https://github.com/habeas-dev/habeas/issues"
  },
  "author": "David Marín",
  "scripts": {
    "test": "node --test extension/test/*.test.mjs",
    "lint": "web-ext lint --source-dir extension",
    "build": "web-ext build --source-dir extension --artifacts-dir dist --overwrite-dest",
    "package": "npm run lint && npm run build"
  },
  "devDependencies": {
    "web-ext": "^8.3.0"
  },
  "files": [
    "README.md"
  ]
}
