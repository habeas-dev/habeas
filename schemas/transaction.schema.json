{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://habeas.dev/schema/transaction@1.json",
  "title": "transaction@1",
  "description": "A normalized financial transaction (card, account or investment movement). Financial adapters are first-party only.",
  "type": "object",
  "required": ["internalId", "date", "amount", "currency"],
  "properties": {
    "internalId": { "type": "string", "description": "Stable id from the source service." },
    "date": { "type": "string", "format": "date-time" },
    "bookedDate": { "type": "string", "format": "date-time" },
    "amount": { "type": "integer", "description": "Signed amount in minor units; negative = outflow." },
    "currency": { "type": "string", "pattern": "^[A-Z]{3}$" },
    "description": { "type": "string" },
    "counterparty": { "type": "string" },
    "account": {
      "type": "object",
      "properties": {
        "type": { "enum": ["current", "savings", "card", "investment", "pension", "other"] },
        "reference": { "type": "string", "description": "Masked account/card reference." }
      }
    },
    "category": { "type": "string", "description": "Source-provided category, if any." },
    "_source": { "type": "string" },
    "_host": { "type": "string" },
    "_capturedAt": { "type": "string", "format": "date-time" },
    "_schema": { "type": "string" }
  }
}
